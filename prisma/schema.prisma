generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id           String   @id @default(cuid())
  source       String   // "viator" | "getyourguide" | "civitatis" | "wordpress" | "manual"
  guestName    String
  guestEmail   String
  tourName     String
  date         DateTime
  participants Int
  duration     Int?     // durée en minutes (ex: 180 = 3h)
  nationality  String?  // ex: "🇫🇷 Francia"
  status       String   @default("pending") // "pending" | "confirmed" | "refused"
  notes        String?
  externalRef  String?  // référence OTA
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Log {
  id        String   @id @default(cuid())
  action    String   // "created" | "confirmed" | "refused" | "deleted"
  bookingId String?
  details   String   // résumé lisible
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}
