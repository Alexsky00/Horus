generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id           String   @id @default(cuid())
  source       String   // "viator" | "getyourguide" | "civitatis" | "wordpress" | "manual"
  guestName    String
  guestEmail   String
  tourName     String
  tourId       String?  // ref to Tour catalog (null for legacy bookings)
  date         DateTime
  participants Int
  duration     Int?     // durée en minutes (ex: 180 = 3h)
  nationality  String?  // ex: "FR"
  routeType    String?  // "corta" | "media" | "larga"
  allDay       Boolean  @default(false)
  status       String   @default("pending") // "pending" | "confirmed" | "refused"
  phone        String?  // téléphone du client
  notes        String?
  externalRef  String?  // référence OTA
  price        Float?   // revenu total de la réservation (€), null = non renseigné
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Tour {
  id          String   @id @default(cuid())
  name        String
  category    String   // "4x4" | "senderismo" | "cultural" | "autobus" | "platform"
  duration    Int      // minutes
  price       Float
  pricingMode String   @default("group") // "group" | "person"
  routeType   String   // "corta" | "media" | "larga"
  platforms   String   // JSON array: ["civitatis"] | ["viator","getyourguide"] | ["wordpress","manual"] | ["manual"]
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model BlockedSlot {
  id        String   @id @default(cuid())
  date      DateTime // début du créneau bloqué
  duration  Int?     // en minutes, null = toute la journée
  allDay    Boolean  @default(false)
  reason    String?
  createdAt DateTime @default(now())
}

model Log {
  id        String   @id @default(cuid())
  action    String   // "created" | "confirmed" | "refused" | "deleted"
  bookingId String?
  details   String   // résumé lisible
  createdAt DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}
