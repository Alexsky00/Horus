# Base de données Supabase (récupère l'URL dans ton projet Supabase > Settings > Database)
DATABASE_URL="postgresql://postgres:[MOT_DE_PASSE]@db.[ID_PROJET].supabase.co:5432/postgres"

# Clés VAPID pour les notifications push
# Génère-les avec : npm run generate:vapid
NEXT_PUBLIC_VAPID_PUBLIC_KEY="ta_cle_publique_vapid"
VAPID_PRIVATE_KEY="ta_cle_privee_vapid"
VAPID_EMAIL="mailto:ton@email.com"

# Email de fallback (optionnel - Gmail avec mot de passe d'application)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="ton@gmail.com"
SMTP_PASS="mot_de_passe_application_gmail"
NOTIFY_EMAIL="ton@email.com"

# Clé secrète pour sécuriser l'endpoint simulate-ota
OTA_WEBHOOK_SECRET="change_moi_en_secret_aleatoire"
